{
  "manifest_version": 3,
  "name": "NeetCode Progress Tracker",
  "description": "Extracts NeetCode progress and syncs topic-wise completion to Supabase.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["https://neetcode.io/*", "https://*.supabase.co/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://neetcode.io/*"],
      "js": ["config.js", "scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
